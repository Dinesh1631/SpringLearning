<?xml version="1.0" encoding="UTF-8"?>

<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
	xmlns:context="http://www.springframework.org/schema/context"
	xsi:schemaLocation="http://www.springframework.org/schema/beans 
	                    http://www.springframework.org/schema/beans/spring-beans-4.0.xsd
        					http://www.springframework.org/schema/context 
        					http://www.springframework.org/schema/context/spring-context-4.0.xsd">
  <context:annotation-config></context:annotation-config>
    
 <bean id="humanHeartObject" class="Spring.Autowiring.Heart">
	 <property name="nameOfAnimal" value="Dinesh"/>
     <property name="noOfHearts" value="1"/>
 </bean>
 <bean id="whaleHeartObject" class="Spring.Autowiring.Heart">
     <property name="nameOfAnimal" value="BigDaddy"/>
     <property name="noOfHearts" value="2"/>
 </bean>
 
<bean id ="body" class="Spring.Autowiring.Body">
</bean>
</beans>